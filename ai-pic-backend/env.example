# 项目配置
PROJECT_NAME=AI图片生成API
VERSION=1.0.0
API_V1_STR=/api/v1

# 安全配置
SECRET_KEY=your-secret-key-here-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 数据库配置 (选择一个)
# SQLite (开发环境)
# DATABASE_URL=sqlite:///./ai_pic.db
# MySQL (生产环境推荐)
DATABASE_URL=mysql+pymysql://root:Pa88word@127.0.0.1:13306/ai_video_studio?charset=utf8mb4
# PostgreSQL:
# DATABASE_URL=postgresql://username:password@localhost/ai_pic

# Redis配置
REDIS_URL=redis://localhost:6379
# Lite 模式可开启 eager（单进程任务执行，不依赖独立 worker/Redis）
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_EAGER_PROPAGATES=true
# SQLite 下若 Alembic 迁移含不兼容语句（如 ALTER COLUMN），可回退 create_all
SQLITE_MIGRATION_FALLBACK_CREATE_ALL=false

# CORS配置
ALLOWED_HOSTS=["http://localhost:3000","http://127.0.0.1:3000"]

# 文件上传配置
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
ALLOWED_EXTENSIONS=[".jpg",".jpeg",".png",".gif"]

# AI服务配置
AI_SERVICE_URL=https://api.openai.com/v1
AI_API_KEY=your-openai-api-key-here
# Lite 模式可强制使用 mock 回退（Story/Episode/Script 文本链路）
AI_FORCE_MOCK=false

# OpenAI配置
OPENAI_API_KEY=your-openai-api-key-here

# Stability AI配置
STABILITY_API_KEY=your-stability-api-key-here

# 邮件配置
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
