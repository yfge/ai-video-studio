# 数据库配置
DATABASE_URL=mysql+pymysql://username:password@localhost:3306/ai_video_studio

# JWT配置
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI服务配置
AI_SERVICE_URL=https://api.your-ai-service.com
AI_API_KEY=your-ai-api-key

# OpenAI配置
OPENAI_API_KEY=sk-your-openai-api-key

# 可灵AI（快手）配置 - 双密钥认证
KELING_API_KEY=your-keling-api-key
KELING_SECRET_KEY=your-keling-secret-key

# 即梦AI配置 - 双密钥认证
JIMENG_API_KEY=your-jimeng-api-key
JIMENG_SECRET_KEY=your-jimeng-secret-key

# MiniMax配置
MINIMAX_API_KEY=your-minimax-api-key
MINIMAX_GROUP_ID=your-minimax-group-id

# DeepSeek配置 - 单密钥
DEEPSEEK_API_KEY=your-deepseek-api-key

# 火山引擎配置 - 双密钥认证
VOLCENGINE_API_KEY=your-volcengine-api-key
VOLCENGINE_SECRET_KEY=your-volcengine-secret-key
VOLCENGINE_REGION=cn-beijing

# 阿里云OSS配置
ALIYUN_ACCESS_KEY_ID=your-aliyun-access-key-id
ALIYUN_ACCESS_KEY_SECRET=your-aliyun-access-key-secret
ALIYUN_OSS_ENDPOINT=https://oss-cn-beijing.aliyuncs.com
ALIYUN_OSS_BUCKET=your-bucket-name
ALIYUN_OSS_DOMAIN=https://your-custom-domain.com

# 上传目录配置
UPLOAD_DIR=./uploads

# Stability AI配置
STABILITY_API_KEY=your-stability-api-key
