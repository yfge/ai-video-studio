FROM node:22.20.0-alpine

WORKDIR /app/ai-pic-frontend
ENV NEXT_TELEMETRY_DISABLED=1

COPY package*.json ./
RUN npm ci
RUN ln -s /app/ai-pic-frontend/node_modules /app/node_modules

# Code is bind-mounted in dev; keep node_modules in image and use anonymous volume to avoid overwrite
CMD ["npm", "run", "dev", "--", "--hostname", "0.0.0.0", "--port", "3000"]
