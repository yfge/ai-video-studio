FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app/ai-pic-backend

# System deps for mysqlclient/pymysql and builds + CA 证书
RUN set -eux; \
    sed -i 's|http://deb.debian.org|https://deb.debian.org|g' /etc/apt/sources.list.d/debian.sources; \
    apt-get update; \
    for i in 1 2 3 4 5; do \
        if apt-get install -y --no-install-recommends \
            ca-certificates \
            build-essential \
            default-libmysqlclient-dev \
            ffmpeg \
            fontconfig \
            fonts-noto-cjk \
            pkg-config; then \
            break; \
        fi; \
        echo "apt-get install failed (attempt ${i}); retrying..." >&2; \
        sleep 2; \
        apt-get update; \
    done; \
    command -v ffmpeg; \
    update-ca-certificates; \
    rm -rf /var/lib/apt/lists/*

COPY requirements.txt requirements-harness.txt ./
RUN pip install --no-cache-dir -c requirements-harness.txt -r requirements.txt

# Code is bind-mounted in dev; container keeps site-packages from build layer
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
