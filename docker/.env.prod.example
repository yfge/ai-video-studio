# Copy to docker/.env for production compose stack

# Image tags used by docker-compose.prod.yml interpolation
IMAGE_TAG=latest

# Backend database/redis connection (matches compose service names)
DATABASE_URL=mysql+pymysql://root:${MYSQL_ROOT_PASSWORD}@ai-video-mysql:3306/ai_video_studio?charset=utf8mb4
REDIS_URL=redis://ai-video-redis:6379/0
SECRET_KEY=change-this-production-secret

# Backend runtime: disable reload for production
UVICORN_RELOAD=0
UVICORN_WORKERS=4

# Optional AI/provider keys
AI_SERVICE_URL=
AI_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
STABILITY_API_KEY=
GOOGLE_API_KEY=
GOOGLE_BASE_URL=
GOOGLE_VIDEO_BASE_URL=
GOOGLE_VERTEX_PROJECT_ID=
GOOGLE_VERTEX_LOCATION=
GOOGLE_VERTEX_ACCESS_TOKEN=
GOOGLE_VERTEX_API_KEY=
GOOGLE_VERTEX_SERVICE_ACCOUNT_JSON=
GOOGLE_VERTEX_SERVICE_ACCOUNT_PATH=
KELING_API_KEY=
KELING_SECRET_KEY=
JIMENG_API_KEY=
JIMENG_SECRET_KEY=
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
DEEPSEEK_API_KEY=
VOLCENGINE_API_KEY=
VOLCENGINE_SECRET_KEY=
VOLCENGINE_REGION=
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_OSS_ENDPOINT=
ALIYUN_OSS_BUCKET=
ALIYUN_OSS_DOMAIN=

# Frontend public API address via nginx prod entrypoint
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_USE_NORMALIZED_BY_DEFAULT=false
