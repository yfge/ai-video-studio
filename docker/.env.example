# Copy to docker/.env for dev stack

# Backend database connection (matches compose service names)
DATABASE_URL=mysql+pymysql://root:ai-video@ai-video-mysql:3306/ai_video_studio?charset=utf8mb4
REDIS_URL=redis://ai-video-redis:6379/0
SECRET_KEY=dev-secret-change-me

# Optional AI/provider keys
AI_SERVICE_URL=
AI_API_KEY=
OPENAI_API_KEY=
STABILITY_API_KEY=
GOOGLE_API_KEY=
# Optional proxy for Gemini API (text/image) requests
GOOGLE_BASE_URL=
# Optional separate base URL for Veo (video) requests (supports proxy gateways)
GOOGLE_VIDEO_BASE_URL=
# Vertex AI Veo routing (required when using the official aiplatform endpoint)
GOOGLE_VERTEX_PROJECT_ID=
GOOGLE_VERTEX_LOCATION=
# Optional OAuth access token (Bearer) for Vertex AI calls (short-lived)
GOOGLE_VERTEX_ACCESS_TOKEN=
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_OSS_ENDPOINT=
ALIYUN_OSS_BUCKET=
ALIYUN_OSS_DOMAIN=

# Frontend API target (goes through nginx single entrypoint)
# - dev: docker-compose.dev.yml maps host 8089 -> nginx 8080
# - prod: docker-compose.prod.yml maps host 8080 -> nginx 8080
NEXT_PUBLIC_API_URL=http://host.docker.internal:8089
NEXT_PUBLIC_USE_NORMALIZED_BY_DEFAULT=false
