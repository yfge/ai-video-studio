# Copy to docker/.env for dev stack

# Backend database connection (matches compose service names)
DATABASE_URL=mysql+pymysql://root:ai-video@ai-video-mysql:3306/ai_video_studio?charset=utf8mb4
REDIS_URL=redis://ai-video-redis:6379/0
SECRET_KEY=dev-secret-change-me

# Optional AI/provider keys
AI_SERVICE_URL=
AI_API_KEY=
OPENAI_API_KEY=
STABILITY_API_KEY=
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_OSS_ENDPOINT=
ALIYUN_OSS_BUCKET=
ALIYUN_OSS_DOMAIN=

# Frontend API target
NEXT_PUBLIC_API_URL=http://localhost:8000
# Toggle normalized storyboard default
NEXT_PUBLIC_USE_NORMALIZED_BY_DEFAULT=false
