# Copy to docker/.env.lite for lite dev stack

# Backend: SQLite + eager Celery（单进程任务执行）
DATABASE_URL=sqlite:////app/ai-pic-backend/uploads/dev_lite.db
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=dev-lite-secret-change-me
CELERY_TASK_ALWAYS_EAGER=true
CELERY_TASK_EAGER_PROPAGATES=true
AI_FORCE_MOCK=true
SQLITE_MIGRATION_FALLBACK_CREATE_ALL=true

# 可选 AI/provider keys（如需接入真实模型可关闭 AI_FORCE_MOCK）
AI_SERVICE_URL=
AI_API_KEY=
OPENAI_API_KEY=
STABILITY_API_KEY=
GOOGLE_API_KEY=
GOOGLE_BASE_URL=
GOOGLE_VIDEO_BASE_URL=
GOOGLE_VERTEX_PROJECT_ID=
GOOGLE_VERTEX_LOCATION=
GOOGLE_VERTEX_ACCESS_TOKEN=
GOOGLE_VERTEX_API_KEY=
GOOGLE_VERTEX_SERVICE_ACCOUNT_JSON=
GOOGLE_VERTEX_SERVICE_ACCOUNT_PATH=
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_OSS_ENDPOINT=
ALIYUN_OSS_BUCKET=
ALIYUN_OSS_DOMAIN=

# Frontend API target (via nginx)
NEXT_PUBLIC_API_URL=http://localhost:8089
NEXT_PUBLIC_HARNESS_RUN_ID=
NEXT_PUBLIC_USE_NORMALIZED_BY_DEFAULT=false

# Backend internal URL for provider callbacks / media fetch
INTERNAL_BACKEND_URL=http://ai-video-backend:8000

# Harness defaults (worktree bootstrap will override these values)
HARNESS_RUN_ID=
HARNESS_WEB_PORT=3000
HARNESS_API_PORT=8000
HARNESS_NGINX_PORT=8089
HARNESS_MODE=lite
HARNESS_PROVIDER_MODE=mock
