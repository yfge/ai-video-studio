---
config:
  flowchart:
    curve: linear
---
graph TD;
	__start__([<p>__start__</p>]):::first
	analyze_scene(analyze_scene)
	think_timing(think_timing)
	propose_gaps(propose_gaps)
	validate_rhythm(validate_rhythm)
	adjust_timing(adjust_timing)
	finalize(finalize)
	__end__([<p>__end__</p>]):::last
	__start__ --> analyze_scene;
	adjust_timing --> validate_rhythm;
	analyze_scene --> think_timing;
	propose_gaps --> validate_rhythm;
	think_timing --> propose_gaps;
	validate_rhythm -.-> adjust_timing;
	validate_rhythm -.-> finalize;
	finalize --> __end__;
	classDef default fill:#f2f0ff,line-height:1.2
	classDef first fill-opacity:0
	classDef last fill:#bfb6fc
